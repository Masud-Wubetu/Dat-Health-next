
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELED
  NO_SHOW
}

enum BloodGroup {
  A_POSITIVE
  A_NEGATIVE
  B_POSITIVE
  B_NEGATIVE
  AB_POSITIVE
  AB_NEGATIVE
  O_POSITIVE
  O_NEGATIVE
}

enum Genotype {
  AA
  AS  
  SS  
  AC
}

enum NotificationType {
  EMAIL
  SMS
  IN_APP
}

enum Specialization {
  GENERAL_PRACTICE
  PEDIATRICS
  CARDIOLOGY
  DERMATOLOGY
  NEUROLOGY
  PSYCHIATRY
  DENTIST
  OPHTHALMOLOGY
  EMERGENCY_MEDICINE
}

model User {
  id                Int                 @id @default(autoincrement())
  name              String
  email             String              @unique
  password          String
  profilePictureUrl String?
  roles             Role[]              @relation("UserRoles") //many-to-many relationship
  doctor            Doctor? //one-to-one relationship. means each user can have at most only one doctor profile
  patient           Patient? //one-to-one relationship
  resetCodes        PasswordResetCode[] //one-to-many relationship. a user can have multiple pasword reset codes
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@map("users") //says the table name in the database should be called users
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[] @relation("UserRoles")

  @@map("roles") //says the table name in the database should be called roles
}

model PasswordResetCode {
  id         Int      @id @default(autoincrement())
  code       String   @unique
  used       Boolean  @default(false)
  expiryDate DateTime
  //fields: [userId] in the PasswordResetCode table is a foreign key.
  //references: [id] It points to User.id.
  //onDelete: Cascade If a User is deleted, their Doctor record is also deleted.
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade) //many-to-one relationship. Connects the foreign key (userId) to User.id
  userId     Int //It stores the ID of the user this reset code belongs to.

  @@map("password_reset_codes") //says the table name in the database should be called password_reset_codes
}

model Doctor {
  id             Int            @id @default(autoincrement())
  firstName      String?
  lastName       String?
  specialization Specialization
  licenseNumber  String

  //fields: [userId] in the Doctor table is a foreign key.
  //references: [id] It points to User.id.
  //onDelete: Cascade If a User is deleted, their Doctor record is also deleted.
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       Int           @unique //the uniqueneess enforces that no two doctor can have same userId
  appointments Appointment[] //one-to-many relationship.

  @@map("doctors") //says the table name in the database should be called doctors
}

model Patient {
  id             Int           @id @default(autoincrement())
  firstName      String?
  lastName       String?
  dateOfBirth    DateTime?
  phone          String?
  knownAllergies String?
  bloodGroup     BloodGroup?
  genotype       Genotype?
  //fields: [userId] in the Patient table is a foreign key.
  //references: [id] It points to User.id.
  //onDelete: Cascade If a User is deleted, their Patient record is also deleted.
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         Int           @unique //the uniqueneess enforces that no two Patient can have same userId
  appointments   Appointment[]

  @@map("patients")
}